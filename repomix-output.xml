"use client";

import React, { useRef } from 'react';
import { motion, useScroll, useTransform, useSpring } from 'framer-motion';
import Link from 'next/link';

const TrappeShowcase: React.FC<{ lang?: 'fr' | 'ma' | 'en' }> = ({ lang = 'fr' }) => {
  const wrapperRef = useRef<HTMLDivElement>(null);
  
  const { scrollYProgress } = useScroll({
    target: wrapperRef,
    offset: ["start start", "end end"]
  });

  const smoothProgress = useSpring(scrollYProgress, {
    stiffness: 100,
    damping: 30,
    restDelta: 0.001
  });

  // 3D Rotation Mapping: -80deg (open) to 0deg (closed)
  const rotateXValue = useTransform(smoothProgress, [0.1, 0.8], [-80, 0]);
  
  // Text Opacity Mapping: Fades in as the door starts closing
  const textOpacity = useTransform(smoothProgress, [0, 0.3, 0.6], [0, 1, 1]);
  const textY = useTransform(smoothProgress, [0, 0.3], [20, 0]);

  // Shadow / Glow Mapping
  const shadowOpacity = useTransform(smoothProgress, [0.4, 0.8], [0, 0.4]);

  const content = {
    fr: {
      titleTop: "Finition Invisible.",
      titleBottom: "Sécurité Absolue.",
      desc: "Nos trappes de visite sur mesure s'intègrent parfaitement à vos faux plafonds. Contrôlez l'ouverture d'un simple geste et profitez d'une finition haut de gamme.",
