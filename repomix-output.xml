                "stockStatus": "En Stock" if in_stock_bool else "En Rupture",
                "ref": p.get('ref'),
                "specs": p.get('specs') or {}
            })
        
        response = jsonify({"status": "success", "products": formatted})
        response.headers["Cache-Control"] = "no-cache, no-store, must-revalidate"
        return response
